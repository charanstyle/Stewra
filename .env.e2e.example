# Stewra E2E — single source of QA credentials for BOTH suites (Playwright web + Maestro mobile).
#
#   cp .env.e2e.example .env.e2e     # .env.e2e is gitignored — never commit real creds
#   # then fill in the two QA users below
#
# The web suite (website/e2e) loads this file directly; the Maestro wrappers
# (frontend/e2e/run-features.sh) source it. Real environment variables always win
# over this file, so CI can inject the same names without a file.
#
# The two users MUST be mutual contacts and email-verified — a `direct` conversation
# only exists between contacts, and every page sits behind email verification.
# These are DEDICATED QA ACCOUNTS: tests run against production (there is no separate
# dev DB), so never point these at a real user.

# Where the site lives. API is same-origin under /api unless E2E_API_URL overrides it.
E2E_WEB_URL=https://www.stewra.com
# E2E_API_URL=            # optional; defaults to $E2E_WEB_URL/api

# QA user A (the caller in web call tests; default actor for API helpers).
E2E_USER_A_EMAIL=user-a@example.com
E2E_USER_A_PASSWORD=

# QA user B (the callee; must be a contact of A).
E2E_USER_B_EMAIL=user-b@example.com
E2E_USER_B_PASSWORD=

# Mobile-only: which conversation the Maestro flows open. Blank = first thread in the list.
E2E_CONTACT_NAME=

# Optional 16 kHz mono WAV fed to WebRTC as fake mic input so speech-to-text
# produces a real transcript in the voice-to-text spec.
# E2E_AUDIO_FILE=
