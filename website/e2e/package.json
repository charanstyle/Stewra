{
  "name": "stewra-website-e2e",
  "private": true,
  "type": "module",
  "description": "End-to-end tests for the Stewra website, driving two real QA sessions with @playwright/test.",
  "scripts": {
    "postinstall": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report .artifacts/report",
    "type-check:e2e": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
