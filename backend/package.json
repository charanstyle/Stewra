{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "description": "Stewra backend \u2014 control plane + agent host + HTTP API",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "tsx src/database/migrate.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.107.0",
    "@sentry/node": "^8.40.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@stewra/agent-runtime": "*",
    "@stewra/shared-types": "*",
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "expo-server-sdk": "^5.0.0",
    "express": "^4.21.1",
    "google-auth-library": "^10.9.0",
    "googleapis": "^173.0.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "kysely": "^0.27.4",
    "multer": "^2.2.0",
    "nodemailer": "^6.10.1",
    "openai": "^6.45.0",
    "pg": "^8.13.1",
    "socket.io": "^4.8.3",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.17.6",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.0"
  }
}
