# Backend env (copy to backend/.env). NEVER commit real secrets.
NODE_ENV=development
PORT=3001

# Dev DB = remote Postgres (container on home:/media/WDHD/docker) reached via SSH tunnel:
#   npm run tunnel    # local 5433 -> home:127.0.0.1:5433
DATABASE_URL=postgresql://stewra:CHANGE_ME@127.0.0.1:5433/stewra

# Auth
JWT_SECRET=CHANGE_ME_min_32_chars_long_secret_value_here
JWT_ACCESS_TTL=2h
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# Vault (AES-256-GCM key, 64 hex chars = 32 bytes). Generate: openssl rand -hex 32
VAULT_KEY=CHANGE_ME_64_hex_chars

# Error tracking (GlitchTip on the remote; optional in M0)
SENTRY_DSN=

# Where the website runs — used for the CORS origin and the post-OAuth redirect back to the app.
WEB_APP_URL=http://localhost:5173

# Outbound email (Mailu/SMTP) used to send the 6-digit verification code. SMTP_SECURE=true means
# implicit TLS on port 465. On the host these come from backend/.mailcredentials (mode 600, gitignored).
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@stewra.com
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=Stewra <no-reply@stewra.com>

# Email-verification policy. Codes expire after TTL minutes; a code locks out after MAX_ATTEMPTS wrong
# tries; a user must wait RESEND_COOLDOWN seconds between requesting new codes.
EMAIL_VERIFICATION_TTL_MINUTES=15
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# Google OAuth (read-only Calendar + Gmail). One consent grants both. Create an OAuth client at
# https://console.cloud.google.com/apis/credentials and set the redirect URI to match below.
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=http://localhost:3001/connections/google/callback

# How many days back Gmail is pulled by default when a user hasn't chosen their own window.
# Users override this per-account in the app (stored as a preference); bounded to 1..90.
GMAIL_LOOKBACK_DAYS=7

# Model provider. Default 'claude_cli' shells out to the locally installed `claude` CLI using your
# existing Claude Code subscription — no API key needed. Alternatives: anthropic | openai | gemini | grok.
MODEL_PROVIDER=claude_cli
# Path/name of the Claude Code binary (only used by claude_cli).
CLAUDE_CODE_PATH=claude
# Model id. Optional for claude_cli (uses your own configured model); REQUIRED for every API provider.
MODEL_ID=
# Optional override for the OpenAI-compatible base URL (proxies/gateways/regions).
MODEL_BASE_URL=
# Only the selected provider's key is required. Names match the product_advisor backend env.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
