# Backend env (copy to backend/.env). NEVER commit real secrets.
NODE_ENV=development
PORT=3001

# Dev DB = remote Postgres (container on home:/media/WDHD/docker) reached via SSH tunnel:
#   npm run tunnel    # local 5433 -> home:127.0.0.1:5433
DATABASE_URL=postgresql://stewra:CHANGE_ME@127.0.0.1:5433/stewra

# Auth
JWT_SECRET=CHANGE_ME_min_32_chars_long_secret_value_here
JWT_ACCESS_TTL=2h
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# Vault (AES-256-GCM key, 64 hex chars = 32 bytes). Generate: openssl rand -hex 32
VAULT_KEY=CHANGE_ME_64_hex_chars

# Error tracking (GlitchTip on the remote; optional in M0)
SENTRY_DSN=

# Where the website runs — used for the CORS origin and the post-OAuth redirect back to the app.
WEB_APP_URL=http://localhost:5173

# Outbound email (Mailu/SMTP) used to send the 6-digit verification code. SMTP_SECURE=true means
# implicit TLS on port 465. On the host these come from backend/.mailcredentials (mode 600, gitignored).
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@stewra.com
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=Stewra <no-reply@stewra.com>

# Email-verification policy. Codes expire after TTL minutes; a code locks out after MAX_ATTEMPTS wrong
# tries; a user must wait RESEND_COOLDOWN seconds between requesting new codes.
EMAIL_VERIFICATION_TTL_MINUTES=15
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# Google OAuth (read-only Calendar + Gmail). One consent grants both. Create an OAuth client at
# https://console.cloud.google.com/apis/credentials and set the redirect URI to match below.
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GOOGLE_REDIRECT_URI=http://localhost:3001/connections/google/callback

# Optional Google tunables — all have safe defaults; override per deploy. Scopes are comma-separated
# and default to the two read-only scopes; widening them here is a visible, auditable change (never
# hardcoded in app code). CONSENT_PROMPT is the plain-language copy shown before the Google redirect.
# CALENDAR_LOOKAHEAD_DAYS is how far ahead the calendar is scanned; MAX_EVENTS/MAX_EMAILS cap how many
# raw records are pulled before minimizing to facts.
# GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar.readonly,https://www.googleapis.com/auth/gmail.readonly
# GOOGLE_CONSENT_PROMPT=Allow Stewra to read your Google Calendar and Gmail? ...
# GOOGLE_CALENDAR_LOOKAHEAD_DAYS=7
# GOOGLE_MAX_EVENTS=50
# GOOGLE_MAX_EMAILS=20

# How many days back Gmail is pulled by default when a user hasn't chosen their own window.
# Users override this per-account in the app (stored as a preference); bounded to 1..90.
GMAIL_LOOKBACK_DAYS=7

# Model provider. Default 'claude_cli' shells out to the locally installed `claude` CLI using your
# existing Claude Code subscription — no API key needed. Alternatives: anthropic | openai | gemini | grok.
MODEL_PROVIDER=claude_cli
# Path/name of the Claude Code binary (only used by claude_cli).
CLAUDE_CODE_PATH=claude
# Model id. Optional for claude_cli (uses your own configured model); REQUIRED for every API provider.
MODEL_ID=
# Optional override for the OpenAI-compatible base URL (proxies/gateways/regions).
MODEL_BASE_URL=
# Only the selected provider's key is required. Names match the product_advisor backend env.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=

# ── Realtime / Messaging / Calls / Voice ────────────────────────────────────────────────────────────
# Redis is REQUIRED (backs the Socket.IO adapter for cross-instance fan-out + the presence store).
# Local dev: a local container (docker run -p 6379:6379 redis) or the SSH tunnel to home's Redis.
REDIS_URL=redis://127.0.0.1:6379

# Audio/video calling. Master switch; when false the /calls routes 503 and signaling stays unwired, so a
# dev box without coturn isn't blocked. When true, TURN_URLS/TURN_SECRET/TURN_REALM are REQUIRED (fail
# loud). Reuses the coturn already on `home` with a DISTINCT Stewra realm + static-auth-secret — see
# deploy/coturn-stewra.md. Force-relay (comma-separated turns: URLs), so calls fail loud, never degrade.
CALLS_ENABLED=false
# TURN_URLS=turns:turn.stewra.com:5349?transport=tcp
# TURN_SECRET=CHANGE_ME_stewra_realm_static_auth_secret
# TURN_REALM=stewra.com
# TURN_CRED_TTL_SECONDS=3600

# Background ringing push credentials — all OPTIONAL (ringing degrades to in-app when unset). APNs
# VoIP/PushKit for iOS; an FCM service-account JSON string for Android data pushes.
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=
# APNS_KEY_P8=
# FCM_SERVICE_ACCOUNT_JSON=

# Talk-to-Stewra voice (local STT/TTS). Master switch; when false /messages/voice 503s so a dev box
# without whisper.cpp/Piper isn't blocked. When true, WHISPER_BIN/WHISPER_MODEL/PIPER_BIN/PIPER_VOICE/
# FFMPEG_BIN/UPLOADS_DIR are REQUIRED. Binaries are invoked via execFile (no shell), config-driven paths.
VOICE_ENABLED=false
# In the prod image these tools are baked into /opt/voice by backend/Dockerfile (INSTALL_VOICE=true) and
# ffmpeg is apt-installed; set VOICE_ENABLED=true + these exact paths in stewra.env. Locally, point them
# at your own builds. ffmpeg normalizes recorded clips (Opus/webm/ogg) to the WAV whisper.cpp needs.
# WHISPER_BIN=/opt/voice/bin/whisper-cli
# WHISPER_MODEL=/opt/voice/models/ggml-base.en.bin
# PIPER_BIN=/opt/voice/piper/piper
# PIPER_VOICE=/opt/voice/piper-voices/en_US-amy-medium.onnx
# FFMPEG_BIN=/usr/bin/ffmpeg
# Where uploaded/synthesized media is written (a mounted volume in prod). Served ONLY via the
# authenticated GET /media/:id — never statically/publicly. MAX_UPLOAD_BYTES caps a clip (default 25 MB).
UPLOADS_DIR=/data/uploads
MAX_UPLOAD_BYTES=26214400

# ── WhatsApp channel (Meta's OFFICIAL Cloud API) ────────────────────────────────────────────────────
# Lets a user talk to Stewra from their own WhatsApp app by messaging STEWRA'S BUSINESS NUMBER — the way
# they'd message an airline. Stewra never touches the user's WhatsApp account, cannot read their other
# chats, and cannot get them banned.
#
# This is the DEFAULT and RECOMMENDED path, and nothing in this section ever logs into a user's account.
# A companion-device client (Baileys-style) that logs into the USER'S OWN WhatsApp is a separate,
# experimental, opt-in channel — see WHATSAPP_PERSONAL_* below — and per build-plan principle 7 it runs
# on the user's own machine and NEVER on Stewra's servers. No Baileys credential, socket, or dependency
# may ever land in the backend.
#
# Master switch. When false, /channels/whatsapp and the webhook 503, so a dev box without a Meta app is
# not blocked. When true, all five values below are REQUIRED (fail loud at boot).
WHATSAPP_ENABLED=false
# Meta's numeric id for the sender number (NOT the number itself). Meta gives you a free TEST number
# immediately — no business verification, no payment — which is enough to build and e2e this.
# WHATSAPP_PHONE_NUMBER_ID=
# Stewra's business number, E.164 WITHOUT the '+', used to build the user's wa.me link.
# WHATSAPP_BUSINESS_NUMBER=15550001111
# A Meta SYSTEM-USER token (never expires). A temp token from the dashboard dies in ~24h — never ship one.
# WHATSAPP_ACCESS_TOKEN=
# Our own random string, echoed back during Meta's GET webhook handshake. Generate: openssl rand -hex 24
# WHATSAPP_VERIFY_TOKEN=
# The Meta APP SECRET — keys the X-Hub-Signature-256 HMAC that authenticates every inbound webhook.
# Without it the webhook would accept a forged POST from anyone who guessed the URL.
# WHATSAPP_APP_SECRET=
# Graph API version, pinned per deploy (Meta deprecates versions on a schedule).
# WHATSAPP_GRAPH_VERSION=v21.0
# How long a link code stays valid. Short by design — it's a possession proof, not a password.
# WHATSAPP_LINK_CODE_TTL_MINUTES=10
#
# ⚠️ COST: replies inside the 24h customer-service window are FREE today, but Meta begins charging for
# service messages on 2026-10-01 (per-message, no volume tiers; rates published 2026-09-01). Every
# Stewra WhatsApp reply becomes a metered cost from that date — re-check before scaling this on.

# ── WhatsApp PERSONAL — EXPERIMENTAL companion device (a SECOND, separate channel) ──────────────────
#
# ⚠️ READ THIS BEFORE SETTING IT TO true.
#
# Everything above is Meta's OFFICIAL Cloud API: users message Stewra's business number, and no user's
# WhatsApp account is ever at risk. This is the other thing. It links the user's OWN WhatsApp account as
# a companion device, which is unofficial, against WhatsApp's terms, and CAN GET THAT ACCOUNT
# PERMANENTLY BANNED. Bans are usually not reversible, and for most people their phone number is also
# their identity for bank codes and 2FA.
#
# It is off by default, gated behind an acknowledgement the user must TYPE OUT, and — per build-plan
# principle 7 — the WhatsApp client itself runs in the Stewra Bridge app on the USER'S OWN COMPUTER.
# There is deliberately no WhatsApp credential in this file for it: the backend never connects to
# WhatsApp, never holds a session, and cannot be made to.
WHATSAPP_PERSONAL_ENABLED=false
# Where users download the Stewra Bridge app. REQUIRED when enabled — no default, because guessing a
# download URL for a security-sensitive desktop binary is not a thing we should ever do quietly.
# WHATSAPP_PERSONAL_DOWNLOAD_URL=https://downloads.stewra.com/bridge
# Oldest bridge build allowed to connect. REQUIRED when enabled. This is a SAFETY control: if a shipped
# bridge turns out to reconnect too aggressively, the accounts it burns are our users' real accounts,
# and this is the lever that stops an old build spreading the damage.
# WHATSAPP_PERSONAL_MIN_BRIDGE_VERSION=1.0.0
# Hard ceiling on outbound sends. Send volume is the single biggest driver of WhatsApp bans, so keep
# this low — it protects the user's account, it is not a throughput tunable.
# WHATSAPP_PERSONAL_MAX_SENDS_PER_MINUTE=10
# How long forwarded WhatsApp message bodies are kept before the retention sweep deletes them.
# WHATSAPP_PERSONAL_RETENTION_DAYS=30
