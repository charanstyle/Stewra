node_modules/
dist/
*.log
.env
.env.*
!.env.example
# Shared E2E QA credentials for both suites — real creds gitignored, template tracked.
!.env.e2e.example
# Production runtime secrets that live beside the deployed app on the host — NEVER commit these.
stewra.env
# Firebase client config for the RN Android app — tied to a specific Firebase project,
# injected via the GOOGLE_SERVICES_JSON env var (see frontend/app.config.ts). Keep it local.
google-services.json
**/google-services.json
.mailcredentials
**/.mailcredentials
.DS_Store
coverage/
.next/
*.tsbuildinfo

# Transient per-session Claude tooling state (copied skills keyed by session id) — not project source.
.claude/hooks/.session-skills/
.apptest
.claude/tsc-cache/

# Expo native project — regenerated from app.config.ts + config plugins on every `expo prebuild`.
# We NEVER hand-edit it or track it: all native config flows through plugins/*.cjs and app.config.ts,
# so the tree stays in sync across machines by regenerating, not by committing generated Gradle output.
/frontend/android/
/frontend/ios/
# Expo local cache + per-machine dev-client device registry.
.expo/
**/.expo/
# `eas build --local` writes its finished artifact here as build-<epoch>.apk (~120 MB).
/frontend/build-*.apk
/frontend/build-*.aab
# ...and the preview/output dir (e.g. build/stewra-preview.apk) — keep it out of git too.
/frontend/build/

# local compiled redis for isolated runner testing (not part of the repo)
.local-redis/
