# REST API origin (no trailing slash, no /api prefix — the backend mounts routes
# at the root and the host nginx strips /api before proxying in production).
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Socket.IO origin. In production this is the public origin fronted by nginx,
# which proxies /api/socket.io/ through to the backend's /socket.io/ path.
EXPO_PUBLIC_WS_BASE_URL=http://localhost:3000

# EAS project id for the Expo project that owns builds + push credentials
# (@nurturinglab/stewra). Created by `eas init`; visible on the EAS dashboard.
# app.config.ts reads it into extra.eas.projectId, which the push registration
# passes to getExpoPushTokenAsync. Required for Expo push + EAS builds.
EAS_PROJECT_ID=
