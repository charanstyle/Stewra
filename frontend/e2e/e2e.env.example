# Copy to e2e.env (gitignored) and fill in, then load before running Maestro:
#   set -a; source e2e.env; set +a
#   maestro test --env EMAIL="$EMAIL" --env PASSWORD="$PASSWORD" \
#     --env CONTACT_NAME="$CONTACT_NAME" flows/full.yaml
#
# Never commit real credentials. These belong to an email-verified test user.

# Credentials for the signed-in user under test.
EMAIL=user@example.com
PASSWORD=your-password

# Which conversation to open in send-message / call flows. Leave blank to use the
# first thread in the list.
CONTACT_NAME=

# Text the message flow sends (optional; has a default).
MESSAGE_TEXT=E2E hello from Maestro
